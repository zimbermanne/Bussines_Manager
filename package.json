{
  "name": "company-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo root — deploy frontend/ and backend/ as separate Railway services.",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run start",
    "start:frontend": "npm --prefix frontend run start",
    "start:backend": "cd backend && python -m uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"
  }
}
